PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/leetmetrices
# Or use MongoDB Atlas:
# MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/leetmetrices

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# Platform APIs (optional - for rate limiting)
LEETCODE_SESSION=
CODEFORCES_API_KEY=
CODEFORCES_API_SECRET=

# AI Recommendations (OpenAI - optional)
OPENAI_API_KEY=

# Frontend URL for CORS
CLIENT_URL=http://localhost:5173
