{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm run railway:build",
    "watchPatterns": [
      "/backend/**",
      "/package.json"
    ]
  },
  "deploy": {
    "startCommand": "npm run railway:start",
    "restartPolicyType": "ON_FAILURE",
    "healthCheckPath": "/api/health",
    "healthCheckTimeout": 100
  }
}
